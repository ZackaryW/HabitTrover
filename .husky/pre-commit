#!/bin/sh

if node -e "const fs=require('fs'); const version=require('./package.json').version; const changelog=fs.readFileSync('CHANGELOG.md', 'utf8'); if (!changelog.includes('## Version ' + version)) { console.error('❌ Error: Version ' + version + ' from package.json not found in CHANGELOG.md'); console.error('Please add an entry for version ' + version + ' in CHANGELOG.md'); process.exit(1); } console.log('✅ Version ' + version + ' found in CHANGELOG.md');"; then
  :
else
  exit 1
fi

npm_exec="npm"
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    npm_exec="npm.cmd"
    ;;
esac

"$npm_exec" run typecheck && "$npm_exec" run lint && "$npm_exec" run test
